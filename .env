# ⚠️  LOCAL DEVELOPMENT ONLY — never upload this file to production
# Production .env lives only on the server and must be edited there directly

DB_HOST=localhost
DB_NAME=ergon_db
DB_USER=root
DB_PASS=
DB_PORT=3306

APP_ENV=development
APP_DEBUG=true
SESSION_LIFETIME=1440

# Notification Services
FCM_SERVER_KEY=your_fcm_key_here
SMS_ACCOUNT_SID=your_sms_sid_here

# SAP PostgreSQL Connection (SSH Tunnel)
SAP_PG_HOST=127.0.0.1
SAP_PG_PORT=5432
SAP_PG_DB=modernsap
SAP_PG_USER=postgres
SAP_PG_PASS=mango