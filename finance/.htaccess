RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Pass measurement-sheet and company-media routes to the main application router
RewriteRule ^measurement-sheet(/.*)?$ ../index.php [QSA,L]
RewriteRule ^company-media(/.*)?$ ../index.php [QSA,L]
RewriteRule ^(.*)$ index.php [QSA,L]
